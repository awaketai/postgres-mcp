# PostgreSQL connection strings (comma-separated for multiple databases)
PG_MCP_DATABASES=postgresql://user:password@localhost:5432/mydb

# Default database (optional, uses the first DSN if omitted)
# PG_MCP_DEFAULT_DB=mydb

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1

# Query settings
# PG_MCP_QUERY_TIMEOUT=30
# PG_MCP_MAX_ROWS=100

# Schema cache
# PG_MCP_SCHEMA_REFRESH_INTERVAL=0
# PG_MCP_SCHEMA_CACHE_PATH=~/.cache/pg-mcp/schema.json

# Logging
# PG_MCP_LOG_LEVEL=INFO
